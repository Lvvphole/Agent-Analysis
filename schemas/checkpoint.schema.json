{
  "$defs": {
    "Decision": {
      "description": "Verifier / final decision values.",
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED",
        "PENDING"
      ],
      "title": "Decision",
      "type": "string"
    },
    "GateResult": {
      "description": "Typed output of every gate.\n\nA gate never mutates state; it only reports a decision and the reasons\nbehind it. The orchestrator is responsible for acting on the result.",
      "properties": {
        "gate_name": {
          "title": "Gate Name",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/GateStatus"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "required_corrections": {
          "items": {
            "type": "string"
          },
          "title": "Required Corrections",
          "type": "array"
        }
      },
      "required": [
        "gate_name",
        "status"
      ],
      "title": "GateResult",
      "type": "object"
    },
    "GateStatus": {
      "description": "Gate decision values (Section 13).",
      "enum": [
        "PASS",
        "FAIL",
        "BLOCKED"
      ],
      "title": "GateStatus",
      "type": "string"
    }
  },
